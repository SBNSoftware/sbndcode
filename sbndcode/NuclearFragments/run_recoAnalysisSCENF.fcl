#include "simulationservices_sbnd.fcl"
#include "backtrackerservice.fcl"
#include "particleinventoryservice.fcl"

#include "recoAnalysisSCEConfigNF.fcl"

process_name: RecoAnalysisNF

services:
{
    @table::sbnd_services
    TFileService: { fileName: "hists_recoAnalysisSCE_%ifb_%p-%tc.root" }
    
    ParticleInventoryService: @local::sbnd_particleinventoryservice
    BackTrackerService:       @local::sbnd_backtrackerservice
}

source:
{
    module_type: RootInput
    maxEvents: -1
}

physics:
{
    analyzers:
    {
        ana: @local::recoAnalysisParams
        anaNF: @local::recoAnalysisParamsNF
    }

    path0: [ ana, ana2 ]
    end_paths: [ path0 ]
    trigger_paths: []
}