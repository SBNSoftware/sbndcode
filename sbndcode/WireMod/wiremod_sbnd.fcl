BEGIN_PROLOG

wiremod_sbnd:
{
    HitLabel: "gaushit"
    WireLabel: "simtpc2d:gauss:DetSim"
    SimChannelLabel: "simtpc2d:simpleSC:DetSim"
    MCPartAssnLabel: "gaushitTruthMatch"
